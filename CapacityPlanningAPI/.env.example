ENVIRONMENT=development
# Use DATABASE_CONNECTION_STRING for SQL Server/LocalDB. It takes precedence over DATABASE_URL.
# DATABASE_CONNECTION_STRING=Server=(localdb)\MSSQLLocalDB;Database=betteams;Trusted_Connection=True;MultipleActiveResultSets=true
DATABASE_URL=postgresql+asyncpg://capacity:capacity@localhost:5432/capacity
DATABASE_ODBC_DRIVER=ODBC Driver 18 for SQL Server
AUTH_MODE=local
LOCAL_JWT_SECRET=replace-with-at-least-32-random-characters
OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_AUDIENCE=api://capacity-planning
OIDC_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
JIRA_WEBHOOK_SECRET=replace-with-a-random-secret
PAYSPACE_WEBHOOK_SECRET=replace-with-a-random-secret
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
ALLOWED_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
