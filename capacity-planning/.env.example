# Server-side URL for the FastAPI v1 API. Do not use NEXT_PUBLIC_ for secrets.
CAPACITY_API_URL=http://127.0.0.1:8000/api/v1

# Development token printed by: python -m app.cli seed --slug demo --name "Demo Organization"
# In deployed environments, forward the signed-in user's Authorization header instead.
CAPACITY_API_TOKEN=
